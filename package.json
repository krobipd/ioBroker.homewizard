{
  "name": "iobroker.homewizard",
  "version": "0.13.0",
  "description": "ioBroker adapter for HomeWizard Energy devices with API v2",
  "author": {
    "name": "krobi",
    "email": "krobi@power-dreams.com"
  },
  "contributors": [
    {
      "name": "Claude (Anthropic)",
      "role": "Coding assistance"
    }
  ],
  "homepage": "https://github.com/krobipd/ioBroker.homewizard",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "homewizard",
    "energy",
    "p1",
    "meter",
    "smartmeter",
    "websocket"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/krobipd/ioBroker.homewizard"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.4.1",
    "bonjour-service": "^1.4.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.3.4",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/iobroker": "npm:@iobroker/types@^7.1.2",
    "@types/node": "^22.19.17",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.9",
    "mocha": "^11.7.6",
    "rimraf": "^6.1.3",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8"
  },
  "files": [
    "admin",
    "build",
    "io-package.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prebuild": "rimraf build",
    "build": "build-adapter ts",
    "watch": "build-adapter ts --watch",
    "check": "tsc --noEmit",
    "test:ts": "vitest run",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:ts && npm run test:package",
    "coverage": "vitest run --coverage",
    "translate": "translate-adapter",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "release-script"
  },
  "bugs": {
    "url": "https://github.com/krobipd/ioBroker.homewizard/issues"
  },
  "main": "build/main.js"
}
